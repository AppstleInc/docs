  "keyFeatures": [
    "Subscription lifecycle management (create, pause, cancel, resume)",
    "Billing & payment processing with automatic retry logic",
    "Loyalty points program with VIP tiers and referral tracking",
    "Membership plans with gated content and access control",
    "Shopify Flow native integration with triggers and actions",
    "Real-time webhooks powered by Svix with signature verification",
    "Customer self-service portal via Shopify App Proxy",
    "JavaScript hooks for storefront widget customization",
    "Shopify metafields and customer/order tags",
    "Partner integration key program for third-party apps"
  ],
  "publicApiSurface": [
    "GET /api/external/v2/subscription-customers/{customerId}",
    "GET /api/external/v2/subscription-contract-details",
    "PUT /api/external/v2/subscription-contracts-update-status",
